{
  "name": "relq",
  "version": "1.0.3",
  "description": "The Fully-Typed PostgreSQL ORM for TypeScript",
  "author": "Olajide Mathew O. <olajide.mathew@yuniq.solutions>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuniqsolutions/relq.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "relq": "./dist/bin/relq.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "require": "./dist/config.cjs",
      "types": "./dist/config/index.d.ts"
    },
    "./schema-builder": {
      "import": "./dist/schema-builder.js",
      "require": "./dist/schema-builder.cjs",
      "types": "./dist/schema-builder.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "postgresql",
    "postgres",
    "query-builder",
    "typescript",
    "orm",
    "database",
    "sql",
    "type-safe",
    "tree-shakeable",
    "zero-dependencies"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "peerDependencies": {}
}